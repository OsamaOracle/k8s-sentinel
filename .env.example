# k8s-sentinel environment variables
# Copy this file to .env and fill in the values

# Set to "true" to run with mock data (no Kubernetes cluster required)
DEV_MODE=false

# LLM Provider: claude, openai, gemini, ollama, azure (default: claude)
LLM_PROVIDER=claude

# Anthropic (default provider)
ANTHROPIC_API_KEY=your-key-here

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Slack webhook URL for anomaly alerts (optional)
SLACK_WEBHOOK_URL=

# Microsoft Teams webhook URL for anomaly alerts (optional)
TEAMS_WEBHOOK_URL=

# Minimum seconds between auto-diagnosis runs when anomalies are present
AUTO_DIAGNOSIS_INTERVAL_SECONDS=300
