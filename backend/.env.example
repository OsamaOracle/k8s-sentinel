# Copy this file to .env and fill in your values.

# Set to true to run without a real Kubernetes cluster (uses mock data).
DEV_MODE=true

# Required for POST /api/diagnose (Claude AI diagnosis).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Slack/Teams webhook URLs for anomaly alerting.
# Leave blank to disable that channel.
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Minimum seconds between repeated alerts for the same anomaly (default 5 min).
ALERT_COOLDOWN_SECONDS=300
